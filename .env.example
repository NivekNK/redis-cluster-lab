# ==========================================
# Configuración del Laboratorio Redis Cluster
# ==========================================

# Rutas de binarios personalizados
# Si usas nix develop, estos pueden quedar como están o ser anulados por el entorno.
DOCKER_BIN=docker
PHP_BIN=php
COMPOSER_BIN=composer

# Límites de Recursos para Docker Compose
# Estos valores evitarán que el cluster sature la máquina host.
# Los masters y replicas de Redis suelen requerir poca CPU y RAM en un entorno de pruebas.
REDIS_MEM_LIMIT=128m
REDIS_CPUS=0.5

# HAProxy consume muy pocos recursos
HAPROXY_MEM_LIMIT=64m
HAPROXY_CPUS=0.2

# El contenedor redis-lab (PHP CLI) puede necesitar más RAM al ejecutar tests masivos
LAB_MEM_LIMIT=256m
LAB_CPUS=0.5
