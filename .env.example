# ==========================================
# Configuración del Laboratorio Redis Cluster
# ==========================================

# Rutas de binarios personalizados
DOCKER_BIN=docker
DOCKER_COMPOSE_BIN=docker compose
DOCKER_BUILDKIT=0

# Límites de Recursos para Docker Compose
# Estos valores evitarán que el cluster sature la máquina host.
# Los masters y replicas de Redis suelen requerir poca CPU y RAM en un entorno de pruebas.
REDIS_MEM_LIMIT=256m
REDIS_CPUS=0.5

# HAProxy consume muy pocos recursos
HAPROXY_MEM_LIMIT=128m
HAPROXY_CPUS=0.5

# Runners de suites
PREDIS_LAB_MEM_LIMIT=512m
PREDIS_LAB_CPUS=1.0

IOREDIS_LAB_MEM_LIMIT=512m
IOREDIS_LAB_CPUS=1.0

# Defaults del runner node/ioredis
IOREDIS_REDIS_MODE=cluster
IOREDIS_REDIS_HOST=redis-node-1
IOREDIS_REDIS_PORT=7000
IOREDIS_REDIS_SCHEME=tcp
